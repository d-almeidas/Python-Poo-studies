from rich import print

class Funcionario:
    """
    Registro de funcionarios
    """
    def __init__(self,nome='Desconhecido',setor='Desconhecido',cargo='Desconhecido'):
        self.nome = nome
        self.cargo = cargo
        self.setor = setor
        
    def __str__(self):
        return f'Ola, sou {self.nome} e sou {self.cargo} do setor de {self.setor}'

c1=Funcionario('maria','adiministração','Diretora')
